# Backend is reached through the Vite dev proxy (see vite.config.js), so the base
# URL is the same-origin /api prefix — NOT the backend URL directly.
VITE_API_BASE_URL=/api

# Teller credentials (demo). Pre-filled on the login form for convenience.
VITE_TELLER_USERNAME=teller
VITE_TELLER_PASSWORD=teller123
